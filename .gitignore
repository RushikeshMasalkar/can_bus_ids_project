*.pth
*.pkl
*.pickle
*.h5
*.hdf5
*.onnx
*.joblib
*.bin
*.safetensors
*.ckpt

# Large datasets (track via Git LFS or DVC instead)
*.csv
*.parquet
*.feather
*.arrow

# Exception: Keep specific config files
!models/threshold.json
!data/vocab.json

