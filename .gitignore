# ==============================================================================
# CAN Bus IDS - Git Ignore Configuration
# ==============================================================================

# ==============================================================================
# PYTHON
# ==============================================================================

# Virtual environments
venv/
env/
.venv/
ENV/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ==============================================================================
# JUPYTER NOTEBOOKS
# ==============================================================================

.ipynb_checkpoints/
*.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ==============================================================================
